@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="text-center mb-5">
    <div class="brand-logo-icon mx-auto mb-4" style="width: 64px; height: 64px; font-size: 2rem;">
        <i class="bi bi-box-seam-fill"></i>
    </div>
    <h2 class="fw-bold slate-950">Welcome Back</h2>
    <p class="text-muted">Managed with precision across the stack</p>
</div>

<div class="auth-card">
    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger border-0 bg-danger-soft text-danger fw-semibold mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
        </div>
    }

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        
        <div class="form-group-custom mb-4">
            <label asp-for="Username">Username or Email</label>
            <div class="position-relative">
                <i class="bi bi-person text-muted position-absolute" style="top: 12px; left: 14px;"></i>
                <input asp-for="Username" type="text" class="input-custom px-5" placeholder="Enter your username" required autofocus />
            </div>
            <span asp-validation-for="Username" class="text-danger text-xs fw-medium mt-1"></span>
        </div>

        <div class="form-group-custom mb-5">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <label asp-for="Password" class="mb-0">Password</label>
                <a href="#" class="text-xs fw-bold text-decoration-none text-brand">Forgot Password?</a>
            </div>
            <div class="position-relative">
                <i class="bi bi-lock text-muted position-absolute" style="top: 12px; left: 14px;"></i>
                <input asp-for="Password" type="password" class="input-custom px-5" placeholder="Enter your password" required />
            </div>
            <span asp-validation-for="Password" class="text-danger text-xs fw-medium mt-1"></span>
        </div>

        <button type="submit" class="btn-brand w-100 justify-content-center py-3 mb-4">
            Sign In to Dashboard <i class="bi bi-arrow-right ms-2"></i>
        </button>

        <p class="text-center text-sm mb-0 text-muted">
            New to the system? <a asp-action="Register" class="fw-bold text-decoration-none text-brand">Create an account</a>
        </p>
    </form>
</div>
