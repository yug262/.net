@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="text-center mb-5">
    <div class="brand-logo-icon mx-auto mb-4" style="width: 64px; height: 64px; font-size: 2rem;">
        <i class="bi bi-box-seam-fill"></i>
    </div>
    <h2 class="fw-bold slate-950">Join the Network</h2>
    <p class="text-muted">Start managing your inventory at scale</p>
</div>

<div class="auth-card">
    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger border-0 bg-danger-soft text-danger fw-semibold mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
        </div>
    }

    @if (Model.SuccessMessage != null)
    {
        <div class="alert alert-success border-0 bg-success-soft text-success fw-semibold mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @Model.SuccessMessage
        </div>
    }

    <form asp-action="Register" method="post">
        @Html.AntiForgeryToken()
        
        <div class="form-group-custom mb-4">
            <label asp-for="Username">Preffered Username</label>
            <div class="position-relative">
                <i class="bi bi-person-plus text-muted position-absolute" style="top: 12px; left: 14px;"></i>
                <input asp-for="Username" type="text" class="input-custom px-5" placeholder="e.g. john_doe" required autofocus />
            </div>
            <span asp-validation-for="Username" class="text-danger text-xs fw-medium mt-1"></span>
        </div>

        <div class="row gx-3">
            <div class="col-md-6 mb-4">
                <div class="form-group-custom">
                    <label asp-for="Password">Password</label>
                    <div class="position-relative">
                        <i class="bi bi-lock text-muted position-absolute" style="top: 12px; left: 14px;"></i>
                        <input asp-for="Password" type="password" class="input-custom px-5" placeholder="Min. 6 chars" required />
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="form-group-custom">
                    <label asp-for="ConfirmPassword">Confirm</label>
                    <div class="position-relative">
                        <i class="bi bi-shield-check text-muted position-absolute" style="top: 12px; left: 14px;"></i>
                        <input asp-for="ConfirmPassword" type="password" class="input-custom px-5" placeholder="Repeat it" required />
                    </div>
                </div>
            </div>
        </div>
        <div class="mb-4">
            <span asp-validation-for="Password" class="text-danger text-xs fw-medium d-block"></span>
            <span asp-validation-for="ConfirmPassword" class="text-danger text-xs fw-medium d-block"></span>
        </div>

        <button type="submit" class="btn-brand w-100 justify-content-center py-3 mb-4">
            Create System Account <i class="bi bi-person-check ms-2"></i>
        </button>

        <p class="text-center text-sm mb-0 text-muted">
            Already have an account? <a asp-action="Login" class="fw-bold text-decoration-none text-brand">Sign in here</a>
        </p>
    </form>
</div>
