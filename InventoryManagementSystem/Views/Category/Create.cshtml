@model CategoryCreateDto
@{
    ViewData["Title"] = "Create Category";
}

<div class="mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb text-xs fw-bold text-muted text-uppercase mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">Define New</li>
        </ol>
    </nav>
    <h2 class="fw-bold slate-950 mb-1">New Category</h2>
    <p class="text-muted text-sm">Establish a new classification for your inventory items.</p>
</div>

<div class="row">
    <div class="col-xl-6">
        <div class="card-container p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                
                <div class="form-group-custom mb-5">
                    <label asp-for="CategoryName">Full Category Name</label>
                    <input asp-for="CategoryName" class="input-custom" placeholder="e.g. Electronics, Perishables, Hardwares" required autofocus />
                    <span asp-validation-for="CategoryName" class="text-danger text-xs fw-medium mt-1"></span>
                    <p class="text-muted text-xs mt-2">Maximum 100 characters. Choose a name that clearly defines the product group.</p>
                </div>

                <div class="d-flex align-items-center gap-3 pt-3">
                    <button type="submit" class="btn-brand px-4">
                        <i class="bi bi-save2"></i> Save Category
                    </button>
                    <a asp-action="Index" class="btn-secondary-light px-4">
                        Discard Changes
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-xl-4 offset-xl-1">
        <div class="bg-indigo-soft p-4 rounded-lg border border-indigo-100 mt-4 mt-xl-0">
            <h6 class="fw-bold text-brand-700 mb-3"><i class="bi bi-info-circle-fill me-2"></i> Design Guidelines</h6>
            <ul class="text-sm text-slate-600 ps-3 mb-0 lh-lg">
                <li>Keep names concise but descriptive.</li>
                <li>Avoid duplicate categories for efficiency.</li>
                <li>Categories help in advanced stock reporting.</li>
            </ul>
        </div>
    </div>
</div>
