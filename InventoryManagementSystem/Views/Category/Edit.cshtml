@model CategoryUpdateDto
@{
    ViewData["Title"] = "Edit Category";
}

<div class="mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb text-xs fw-bold text-muted text-uppercase mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">Modify Definition</li>
        </ol>
    </nav>
    <h2 class="fw-bold slate-950 mb-1">Update Category</h2>
    <p class="text-muted text-sm">Renaming or archiving a category affects how products are grouped in reports.</p>
</div>

<div class="row">
    <div class="col-xl-6">
        <div class="card-container p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                
                <div class="form-group-custom mb-5">
                    <label asp-for="CategoryName">Updated Category Name</label>
                    <input asp-for="CategoryName" class="input-custom" placeholder="Enter new name" required autofocus />
                    <span asp-validation-for="CategoryName" class="text-danger text-xs fw-medium mt-1"></span>
                </div>

                <div class="d-flex align-items-center gap-3 pt-3">
                    <button type="submit" class="btn-brand px-4">
                        <i class="bi bi-check-lg"></i> Update Records
                    </button>
                    <a asp-action="Index" class="btn-secondary-light px-4">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-xl-4 offset-xl-1">
        <div class="bg-indigo-soft p-4 rounded-lg border border-indigo-100 mt-4 mt-xl-0">
            <h6 class="fw-bold text-brand-700 mb-3"><i class="bi bi-shield-lock-fill me-2"></i> System Integrity</h6>
            <p class="text-xs text-slate-600 mb-0">
                Modification of category names will propagate across all linked products instantly. 
                Use this feature to correct legacy naming conventions.
            </p>
        </div>
    </div>
</div>
