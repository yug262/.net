@model List<CustomerReadDto>
@{
    ViewData["Title"] = "Customer Directory";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5">
    <div>
        <h2 class="fw-bold slate-950 mb-1">Customer Directory</h2>
        <p class="text-muted text-sm mb-0">Manage your customer base and track purchase history.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn-brand">
            <i class="bi bi-plus-circle me-1"></i> Add Customer
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 bg-success-soft text-success fw-semibold mb-5 p-3 d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-3 fs-5"></i> @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger border-0 bg-danger-soft text-danger fw-semibold mb-5 p-3 d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-3 fs-5"></i> @TempData["ErrorMessage"]
    </div>
}

<!-- Search Bar -->
<div class="card-container p-3 mb-4 bg-slate-50 border-dashed">
    <form asp-action="Index" method="get" class="row g-3 align-items-center">
        <div class="col-md-9 col-lg-6">
            <div class="position-relative">
                <i class="bi bi-search text-muted position-absolute" style="top: 10px; left: 14px;"></i>
                <input type="text" name="searchQuery" value="@ViewData["CurrentFilter"]" class="input-custom px-5" placeholder="Search by name, phone, or email..." />
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-brand w-100 py-2">Search</button>
        </div>
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
        {
            <div class="col-md-2">
                <a asp-action="Index" class="text-sm fw-bold text-brand-600 text-decoration-none">Clear</a>
            </div>
        }
    </form>
</div>

<div class="card-container">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <div class="bg-indigo-soft rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                <i class="bi bi-person-lines-fill fs-1 text-brand-500"></i>
            </div>
            <h5 class="fw-bold slate-800">No customers found</h5>
            <p class="text-muted text-sm mx-auto" style="max-width: 320px;">Start building your customer base by adding a new customer.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-modern mb-0">
                <thead>
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Customer</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Total Orders</th>
                        <th>Added</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="text-xs fw-bold text-slate-400">@item.Id</span></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-indigo-soft rounded d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                        <i class="bi bi-person-fill text-brand-500"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold slate-900">@item.CustomerName</div>
                                        @if (item.TotalSpent > 0)
                                        {
                                            <div class="text-xs text-muted">₹@item.TotalSpent.ToString("N2") spent</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span class="text-sm fw-medium">@(item.Phone ?? "—")</span></td>
                            <td><span class="text-sm">@(item.Email ?? "—")</span></td>
                            <td>
                                <span class="badge-pill bg-indigo-soft text-brand-700">@item.TotalOrders orders</span>
                            </td>
                            <td><span class="text-xs text-muted">@item.CreatedAt.ToShortDateString()</span></td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary-light p-2" title="View"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary-light p-2" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                          onsubmit="return confirm('Delete this customer?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm bg-danger-soft text-danger p-2 border-0" title="Delete"><i class="bi bi-trash3-fill"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
