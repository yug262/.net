@model CustomerFormViewModel
@{
    ViewData["Title"] = "Add Customer";
}

<div class="mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb text-xs fw-bold text-muted text-uppercase mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Customers</a></li>
            <li class="breadcrumb-item active" aria-current="page">New</li>
        </ol>
    </nav>
    <h2 class="fw-bold slate-950 mb-1">Add Customer</h2>
    <p class="text-muted text-sm">Register a new customer in the system.</p>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-4">
        <div class="col-xl-8">
            <div class="card-container p-4 mb-4">
                <h6 class="fw-bold slate-900 border-bottom pb-3 mb-4">Customer Information</h6>
                <div class="row gx-4">
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="CustomerName">Customer Name</label>
                            <input asp-for="CustomerName" class="input-custom" placeholder="e.g. Rohit Sharma" required />
                            <span asp-validation-for="CustomerName" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="Phone">Phone Number</label>
                            <div class="position-relative">
                                <i class="bi bi-telephone text-muted position-absolute" style="top: 10px; left: 14px;"></i>
                                <input asp-for="Phone" class="input-custom ps-5" placeholder="+91 98765 43210" />
                            </div>
                            <span asp-validation-for="Phone" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group-custom mb-4">
                    <label asp-for="Email">Email Address</label>
                    <div class="position-relative">
                        <i class="bi bi-envelope text-muted position-absolute" style="top: 10px; left: 14px;"></i>
                        <input asp-for="Email" type="email" class="input-custom ps-5" placeholder="customer@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger text-xs fw-medium mt-1"></span>
                </div>
                <div class="form-group-custom mb-0">
                    <label asp-for="Address">Address</label>
                    <textarea asp-for="Address" class="input-custom" rows="3" placeholder="Street, City, State, PIN..."></textarea>
                    <span asp-validation-for="Address" class="text-danger text-xs fw-medium mt-1"></span>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="card-container p-4 sticky-top" style="top: 2rem; z-index: 10;">
                <h6 class="fw-bold slate-900 mb-4">Actions</h6>
                <button type="submit" class="btn btn-brand w-100 py-3 mb-3"><i class="bi bi-save me-2"></i> Save Customer</button>
                <a asp-action="Index" class="btn btn-secondary-light w-100 py-3">Cancel</a>
            </div>
        </div>
    </div>
</form>
