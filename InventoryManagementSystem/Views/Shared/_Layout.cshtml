<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — IMS Dashboard</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Icons & Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    
    <!-- Custom Style -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="app-layout">
            <!-- Sidebar -->
            <aside class="sidebar">
                <div class="brand-section">
                    <a asp-controller="Home" asp-action="Index" class="brand-logo">
                        <div class="brand-logo-icon">
                            <i class="bi bi-box-seam-fill"></i>
                        </div>
                        <span>InventoryPro</span>
                    </a>
                </div>

                <div class="nav-group">
                    <div class="nav-label">Main Menu</div>
                    <nav class="nav flex-column">
                        <a asp-controller="Home" asp-action="Index"
                           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                            <i class="bi bi-columns-gap"></i> Dashboard
                        </a>
                        <a asp-controller="Category" asp-action="Index"
                           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                            <i class="bi bi-folder2-open"></i> Categories
                        </a>
                        <a asp-controller="Product" asp-action="Index"
                           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" && ViewContext.RouteData.Values["action"]?.ToString() != "LowStock" ? "active" : "")">
                            <i class="bi bi-box2-heart"></i> Products
                        </a>
                    </nav>
                </div>

                <div class="nav-group">
                    <div class="nav-label">Inventory Control</div>
                    <nav class="nav flex-column">
                        <a asp-controller="Product" asp-action="LowStock"
                           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LowStock" ? "active" : "")">
                            <i class="bi bi-shield-exclamation text-warning"></i> Low Stock Alerts
                        </a>
                        <a asp-controller="Order" asp-action="Index"
                           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                            <i class="bi bi-receipt"></i> Sales & Orders
                        </a>
                    </nav>
                </div>

                <div class="logout-footer">
                    <div class="text-xs fw-semibold text-muted mb-3 opacity-50 px-2">LOGGED IN AS</div>
                    <div class="d-flex align-items-center gap-3 px-2 mb-4">
                        <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.75rem;">
                            @User.Identity.Name?[..1].ToUpper()
                        </div>
                        <div class="text-sm fw-semibold">@User.Identity.Name</div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-sidebar-secondary">
                            <i class="bi bi-power"></i> Sign Out
                        </button>
                    </form>
                </div>
            </aside>

            <!-- Main content content -->
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <div class="auth-wrapper">
            <div class="auth-inner">
                @RenderBody()
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
