@model DashboardStatsDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-5">
    <h2 class="fw-bold slate-950 mb-1">Command Center</h2>
    <p class="text-muted text-sm">Real-time overview of your inventory operations and logistics.</p>
</div>

<!-- Primary Stats Grid -->
<div class="row g-4 mb-5">
    <!-- Total Categories -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-widget">
            <div class="widget-icon-box bg-indigo-soft text-brand-600">
                <i class="bi bi-tags"></i>
            </div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase letter-spacing-05 mb-1">Categories</div>
                <div class="h4 fw-bold mb-0">@Model.TotalCategories</div>
                <a asp-controller="Category" asp-action="Index" class="text-xs fw-semibold text-brand text-decoration-none mt-2 d-inline-block">View all categories <i class="bi bi-chevron-right ms-1"></i></a>
            </div>
        </div>
    </div>

    <!-- Total Products -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-widget">
            <div class="widget-icon-box bg-indigo-soft text-brand-600" style="background: #eff6ff; color: #3b82f6;">
                <i class="bi bi-box"></i>
            </div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase letter-spacing-05 mb-1">Total Assets</div>
                <div class="h4 fw-bold mb-0">@Model.TotalProducts</div>
                <a asp-controller="Product" asp-action="Index" class="text-xs fw-semibold text-primary text-decoration-none mt-2 d-inline-block" style="color: #3b82f6 !important;">Inventory ledger <i class="bi bi-chevron-right ms-1"></i></a>
            </div>
        </div>
    </div>

    <!-- Inventory Value -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-widget">
            <div class="widget-icon-box bg-indigo-soft text-brand-600" style="background: #fdf2f7; color: #db2777;">
                <i class="bi bi-bank"></i>
            </div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase letter-spacing-05 mb-1">Inventory Value</div>
                <div class="h4 fw-bold mb-0">₹@Model.InventoryValue.ToString("N2")</div>
                <a asp-controller="Product" asp-action="Index" class="text-xs fw-semibold text-decoration-none mt-2 d-inline-block" style="color: #db2777 !important;">View inventory <i class="bi bi-chevron-right ms-1"></i></a>
            </div>
        </div>
    </div>

    <!-- Today's Units Sold -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-widget">
            <div class="widget-icon-box bg-success-soft text-success">
                <i class="bi bi-truck"></i>
            </div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase letter-spacing-05 mb-1">Units Dispatched</div>
                <div class="h4 fw-bold mb-0">@Model.TotalSold</div>
                <a asp-controller="Order" asp-action="Index" class="text-xs fw-semibold text-success text-decoration-none mt-2 d-inline-block">View orders <i class="bi bi-chevron-right ms-1"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- Secondary Stats Row -->
<div class="row g-4 mb-5">
    <!-- Total Customers -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-widget">
            <div class="widget-icon-box" style="background: #fef3c7; color: #d97706;">
                <i class="bi bi-person-lines-fill"></i>
            </div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase letter-spacing-05 mb-1">Customers</div>
                <div class="h4 fw-bold mb-0">@Model.TotalCustomers</div>
                <a asp-controller="Customer" asp-action="Index" class="text-xs fw-semibold text-decoration-none mt-2 d-inline-block" style="color: #d97706 !important;">View customers <i class="bi bi-chevron-right ms-1"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Low Stock Alert Box -->
    <div class="col-xl-4">
        <div class="card-container h-100 p-4" style="background: linear-gradient(135deg, #fffbeb 0%, #fff 100%); border-color: #fde68a;">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="widget-icon-box bg-warning-soft text-warning">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-0">Priority Alerts</h5>
                    <p class="text-muted text-xs mb-0">Refill required immediately</p>
                </div>
            </div>
            <div class="mb-4">
                <div class="display-6 fw-bold text-warning">@Model.LowStockProducts</div>
                <div class="text-sm fw-medium text-warning opacity-75">Critical Low Stock Items</div>
            </div>
            <a asp-controller="Product" asp-action="LowStock" class="btn btn-brand w-100 bg-warning border-0 hover-opacity-90">
                Generate Restock List <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    </div>

    <!-- Out of Stock Box -->
    <div class="col-xl-4">
        <div class="card-container h-100 p-4" style="background: linear-gradient(135deg, #fef2f2 0%, #fff 100%); border-color: #fecaca;">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="widget-icon-box bg-danger-soft text-danger">
                    <i class="bi bi-shield-x"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-0">Out of Stock</h5>
                    <p class="text-muted text-xs mb-0">Items with null quantity</p>
                </div>
            </div>
            <div class="mb-4">
                <div class="display-6 fw-bold text-danger">@Model.OutOfStockProducts</div>
                <div class="text-sm fw-medium text-danger opacity-75">Depleted Inventory Items</div>
            </div>
            <a asp-controller="Product" asp-action="Index" class="btn btn-brand w-100 bg-danger border-0 hover-opacity-90">
                Review Inventory <i class="bi bi-search ms-2"></i>
            </a>
        </div>
    </div>

    <!-- Today's Profit Box -->
    <div class="col-xl-4">
        <div class="card-container h-100 p-0" style="background: linear-gradient(135deg, #ecfdf5 0%, #fff 100%); border-color: #a7f3d0; overflow: hidden;">
             <div class="d-flex border-bottom" style="border-color: rgba(167, 243, 208, 0.5) !important;">
                <button class="btn btn-link text-decoration-none flex-grow-1 text-center py-3 rounded-0 fw-bold border-end text-success" style="border-color: rgba(167, 243, 208, 0.5) !important; background-color: rgba(167, 243, 208, 0.2);" onclick="switchProfitTab('today', this)">Today</button>
                <button class="btn btn-link text-decoration-none flex-grow-1 text-center py-3 rounded-0 fw-bold text-muted" onclick="switchProfitTab('custom', this)">Custom Range</button>
            </div>
            
            <div class="p-4" id="profit-today-view">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="widget-icon-box bg-success-soft text-success">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Daily Revenue</h5>
                        <p class="text-muted text-xs mb-0">Profit realized today</p>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="display-6 fw-bold text-success">₹@Model.TodayProfit.ToString("N2")</div>
                    <div class="text-sm fw-medium text-success opacity-75">Net Profit (Sell - Buy)</div>
                </div>
                <div class="text-xs text-muted">
                    <i class="bi bi-info-circle me-1"></i> Based on orders placed in last 24h
                </div>
            </div>

            <div class="p-4 d-none" id="profit-custom-view">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="widget-icon-box bg-success-soft text-success" style="width: 32px; height: 32px; font-size: 14px;">
                        <i class="bi bi-calendar-range"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0 text-success">Custom Range</h6>
                    </div>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="text-xs fw-bold text-muted mb-1">Start Date</label>
                        <input type="date" id="profitStartDate" class="form-control px-2 py-1 text-sm bg-white border-success border-opacity-25" style="border-radius: 8px;" />
                    </div>
                    <div class="col-6">
                        <label class="text-xs fw-bold text-muted mb-1">End Date</label>
                        <input type="date" id="profitEndDate" class="form-control px-2 py-1 text-sm bg-white border-success border-opacity-25" style="border-radius: 8px;" />
                    </div>
                </div>
                <button class="btn btn-sm btn-brand w-100 bg-success border-0 hover-opacity-90 mb-3 py-2" onclick="calculateCustomProfit()">
                    Calculate Profit
                </button>
                <div class="text-center p-3 bg-white rounded border border-success border-opacity-25" id="customProfitResult" style="display: none;">
                    <div class="text-xs text-muted mb-1">Calculated Profit</div>
                    <div class="h3 fw-bold text-success mb-0" id="customProfitValue">₹0.00</div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing-05 { letter-spacing: 0.05em; }
    .hover-opacity-90:hover { opacity: 0.9; }
</style>

<script>
    function switchProfitTab(tab, element) {
        document.getElementById('profit-today-view').classList.toggle('d-none', tab !== 'today');
        document.getElementById('profit-custom-view').classList.toggle('d-none', tab !== 'custom');
        
        const tabs = element.parentElement.children;
        for (let t of tabs) {
            t.classList.remove('text-success', 'text-muted');
            if (t === element) {
                t.classList.add('text-success');
                t.style.backgroundColor = 'rgba(167, 243, 208, 0.2)';
            } else {
                t.classList.add('text-muted');
                t.style.backgroundColor = 'transparent';
            }
        }
    }

    async function calculateCustomProfit() {
        const startDate = document.getElementById('profitStartDate').value;
        const endDate = document.getElementById('profitEndDate').value;
        
        if (!startDate || !endDate) {
            alert('Please select both a start and end date.');
            return;
        }

        try {
            const response = await fetch(`/Home/GetProfit?startDate=${startDate}&endDate=${endDate}`);
            if (response.ok) {
                const data = await response.json();
                document.getElementById('customProfitValue').innerText = '₹' + data.profit.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('customProfitResult').style.display = 'block';
            } else {
                alert('Failed to retrieve profit data.');
            }
        } catch (error) {
            console.error('Error fetching profit:', error);
            alert('An unexpected error occurred.');
        }
    }
</script>
