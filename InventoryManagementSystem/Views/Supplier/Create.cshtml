@model SupplierFormViewModel
@{
    ViewData["Title"] = "Add Supplier";
}

<div class="mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb text-xs fw-bold text-muted text-uppercase mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Suppliers</a></li>
            <li class="breadcrumb-item active" aria-current="page">New Supplier</li>
        </ol>
    </nav>
    <h2 class="fw-bold slate-950 mb-1">Add Supplier</h2>
    <p class="text-muted text-sm">Register a new vendor in the system.</p>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-4">
        <!-- Main Info -->
        <div class="col-xl-8">
            <div class="card-container p-4 mb-4">
                <h6 class="fw-bold slate-900 border-bottom pb-3 mb-4">Supplier Information</h6>

                <div class="row gx-4">
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="SupplierName">Supplier Name</label>
                            <input asp-for="SupplierName" class="input-custom" placeholder="e.g. John Doe" required />
                            <span asp-validation-for="SupplierName" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="CompanyName">Company Name</label>
                            <input asp-for="CompanyName" class="input-custom" placeholder="e.g. Acme Corp" />
                            <span asp-validation-for="CompanyName" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                </div>

                <div class="row gx-4">
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="Phone">Phone Number</label>
                            <div class="position-relative">
                                <i class="bi bi-telephone text-muted position-absolute" style="top: 10px; left: 14px;"></i>
                                <input asp-for="Phone" class="input-custom ps-5" placeholder="+91 98765 43210" />
                            </div>
                            <span asp-validation-for="Phone" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="Email">Email Address</label>
                            <div class="position-relative">
                                <i class="bi bi-envelope text-muted position-absolute" style="top: 10px; left: 14px;"></i>
                                <input asp-for="Email" type="email" class="input-custom ps-5" placeholder="supplier@company.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group-custom mb-0">
                    <label asp-for="Address">Address</label>
                    <textarea asp-for="Address" class="input-custom" rows="3" placeholder="Street, City, State, PIN..."></textarea>
                    <span asp-validation-for="Address" class="text-danger text-xs fw-medium mt-1"></span>
                </div>
            </div>
        </div>

        <!-- Sidebar / Actions -->
        <div class="col-xl-4">
            <div class="card-container p-4 sticky-top" style="top: 2rem; z-index: 10;">
                <h6 class="fw-bold slate-900 mb-4">Control Actions</h6>
                <button type="submit" class="btn btn-brand w-100 py-3 mb-3">
                    <i class="bi bi-save me-2"></i> Save Supplier
                </button>
                <a asp-action="Index" class="btn btn-secondary-light w-100 py-3 mb-4">
                    Cancel
                </a>

                <div class="bg-indigo-soft p-3 rounded">
                    <div class="text-xs fw-bold text-brand-700 text-uppercase mb-2">Info</div>
                    <p class="text-xs text-slate-600 mb-0 lh-base">
                        Once registered, this supplier can be referenced in future procurement workflows.
                    </p>
                </div>
            </div>
        </div>
    </div>
</form>
