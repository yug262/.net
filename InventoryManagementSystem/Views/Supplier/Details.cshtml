@model SupplierReadDto
@{
    ViewData["Title"] = "Supplier Details";
}

<div class="mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb text-xs fw-bold text-muted text-uppercase mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Suppliers</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>
    <h2 class="fw-bold slate-950 mb-1">Supplier Profile</h2>
    <p class="text-muted text-sm">Full information for this vendor record.</p>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="card-container p-4">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                <h6 class="fw-bold slate-900 mb-0">Vendor Details</h6>
                <span class="badge-pill bg-indigo-soft text-brand-700">ID: #@Model.Id</span>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="mb-4">
                        <div class="text-xs fw-bold text-muted text-uppercase mb-1">Supplier Name</div>
                        <div class="fw-bold slate-900 fs-6">@Model.SupplierName</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-4">
                        <div class="text-xs fw-bold text-muted text-uppercase mb-1">Company Name</div>
                        <div class="fw-bold slate-900 fs-6">@(Model.CompanyName ?? "—")</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-4">
                        <div class="text-xs fw-bold text-muted text-uppercase mb-1">Phone</div>
                        <div class="fw-semibold">
                            @if (!string.IsNullOrEmpty(Model.Phone))
                            {
                                <i class="bi bi-telephone me-1 text-muted"></i> @Model.Phone
                            }
                            else
                            {
                                <span class="text-muted">Not provided</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-4">
                        <div class="text-xs fw-bold text-muted text-uppercase mb-1">Email</div>
                        <div class="fw-semibold">
                            @if (!string.IsNullOrEmpty(Model.Email))
                            {
                                <i class="bi bi-envelope me-1 text-muted"></i> @Model.Email
                            }
                            else
                            {
                                <span class="text-muted">Not provided</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="mb-4">
                        <div class="text-xs fw-bold text-muted text-uppercase mb-1">Address</div>
                        <div class="fw-semibold">
                            @if (!string.IsNullOrEmpty(Model.Address))
                            {
                                <i class="bi bi-geo-alt me-1 text-muted"></i> @Model.Address
                            }
                            else
                            {
                                <span class="text-muted">Not provided</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-0">
                        <div class="text-xs fw-bold text-muted text-uppercase mb-1">Created On</div>
                        <div class="fw-semibold">
                            <i class="bi bi-calendar3 me-1 text-muted"></i> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions Sidebar -->
    <div class="col-xl-4">
        <div class="card-container p-4 sticky-top" style="top: 2rem; z-index: 10;">
            <h6 class="fw-bold slate-900 mb-4">Quick Actions</h6>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand w-100 py-3 mb-3">
                <i class="bi bi-pencil-square me-2"></i> Edit Supplier
            </a>
            <a asp-action="Index" class="btn btn-secondary-light w-100 py-3 mb-3">
                Back to Directory
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Are you sure you want to delete this supplier?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn bg-danger-soft text-danger w-100 py-3 border-0">
                    <i class="bi bi-trash3-fill me-2"></i> Delete Supplier
                </button>
            </form>
        </div>
    </div>
</div>
