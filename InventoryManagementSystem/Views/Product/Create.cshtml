@model ProductFormViewModel
@{
    ViewData["Title"] = "Register Asset";
}

<div class="mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb text-xs fw-bold text-muted text-uppercase mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Warehouse</a></li>
            <li class="breadcrumb-item active" aria-current="page">New Registration</li>
        </ol>
    </nav>
    <h2 class="fw-bold slate-950 mb-1">Asset Registration</h2>
    <p class="text-muted text-sm">Onboard a new product into the system inventory.</p>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-4">
        <!-- Main Info -->
        <div class="col-xl-8">
            <div class="card-container p-4 mb-4">
                <h6 class="fw-bold slate-900 border-bottom pb-3 mb-4">Core Identification</h6>
                
                <div class="row gx-4">
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="ProductName">Product Asset Name</label>
                            <input asp-for="ProductName" class="input-custom" placeholder="e.g. Wireless Keyboard V2" required />
                            <span asp-validation-for="ProductName" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="SKU">Stock Keeping Unit (SKU)</label>
                            <input asp-for="SKU" class="input-custom" placeholder="e.g. KB-WL-V2-BL" required />
                            <span asp-validation-for="SKU" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                </div>

                <div class="row gx-4">
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="CategoryId">Catalog Category</label>
                            <select asp-for="CategoryId" class="input-custom form-select" asp-items="@(new SelectList(Model.Categories, "Id", "CategoryName"))" required>
                                <option value="">— Select Classification —</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="Quantity">Initial Stock Qty</label>
                            <div class="position-relative">
                                <i class="bi bi-stack text-muted position-absolute" style="top: 10px; left: 14px;"></i>
                                <input asp-for="Quantity" type="number" class="input-custom ps-5" placeholder="0" required />
                            </div>
                            <span asp-validation-for="Quantity" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group-custom mb-0">
                    <label asp-for="Description">Product Specifications</label>
                    <textarea asp-for="Description" class="input-custom" rows="3" placeholder="Technical specifications, dimensions, or usage notes..."></textarea>
                    <span asp-validation-for="Description" class="text-danger text-xs fw-medium mt-1"></span>
                </div>
            </div>

            <div class="card-container p-4">
                <h6 class="fw-bold slate-900 border-bottom pb-3 mb-4">Financial Ledger</h6>
                <div class="row gx-4">
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="PurchasePrice">Unit Acquisition Cost (Buy)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-slate-50 border-slate-200">₹</span>
                                <input asp-for="PurchasePrice" type="number" step="0.01" class="form-control input-custom" placeholder="0.00" required />
                            </div>
                            <span asp-validation-for="PurchasePrice" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="form-group-custom">
                            <label asp-for="SellingPrice">Unit Standard Price (Sell)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-slate-50 border-slate-200">₹</span>
                                <input asp-for="SellingPrice" type="number" step="0.01" class="form-control input-custom" placeholder="0.00" required />
                            </div>
                            <span asp-validation-for="SellingPrice" class="text-danger text-xs fw-medium mt-1"></span>
                        </div>
                    </div>
                </div>
                <div class="bg-slate-50 p-3 rounded text-xs text-muted">
                    <i class="bi bi-info-circle me-1"></i> Profit margins are automatically calculated based on Acquisition vs Standard price.
                </div>
            </div>
        </div>

        <!-- Sidebar / Actions -->
        <div class="col-xl-4">
            <div class="card-container p-4 sticky-top" style="top: 2rem; z-index: 10;">
                <h6 class="fw-bold slate-900 mb-4">Control Actions</h6>
                <button type="submit" class="btn btn-brand w-100 py-3 mb-3">
                    <i class="bi bi-cloud-upload me-2"></i> Commit Registration
                </button>
                <a asp-action="Index" class="btn btn-secondary-light w-100 py-3 mb-4">
                    Return to Warehouse
                </a>
                
                <div class="bg-indigo-soft p-3 rounded">
                    <div class="text-xs fw-bold text-brand-700 text-uppercase mb-2">Notice</div>
                    <p class="text-xs text-slate-600 mb-0 lh-base">
                        By registering this asset, historical tracking begins immediately. Stock movements will be logged in reports.
                    </p>
                </div>
            </div>
        </div>
    </div>
</form>
